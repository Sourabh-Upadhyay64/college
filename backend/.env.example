# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/bicycle-marketplace

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Resend Email Service (Get free API key from resend.com)
# Sign up at https://resend.com to get your API key (100 free emails/day)
# Leave as 'demo' to use simulation mode (OTP will be logged to console)
RESEND_API_KEY=demo

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Allowed Email Domain
ALLOWED_EMAIL_DOMAIN=birlainstitute.co.in

# OTP Configuration
OTP_EXPIRE_MINUTES=10
